<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent" android:orientation="vertical">

    <TextView
            android:text="TextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/detail_title"/>
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent" android:layout_weight="1">
        <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:id="@+id/detail_text"/>
    </ScrollView>
    <Button
            android:text="打开外部链接"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/share_link"/>
    <Button
            android:text="应用内下载"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/download"/>
</LinearLayout>